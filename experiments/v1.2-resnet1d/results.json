{
  "experiment": "v1.2_hybrid_multiscale_resnet1d",
  "model": "hybrid_multiscale_resnet1d",
  "parameters": 2144069,

  "architecture": {
    "type": "Hybrid Multi-Scale ResNet1D",
    "input_channels": 2,
    "output_classes": 5,

    "channels": [32, 64, 128, 256],
    "residual_blocks": [2, 2, 2, 2],

    "kernel_sizes": {
      "stem": 7,
      "stage1": 7,
      "stage2": 9,
      "stage3": 13,
      "stage4": 17
    },

    "stage_configuration": {
      "stage1": "depthwise_separable",
      "stage2": "depthwise_separable",
      "stage3": "standard_conv",
      "stage4": "standard_conv"
    },

    "normalization": "none",
    "dropout": 0.3
  },

  "training": {
