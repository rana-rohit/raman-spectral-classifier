    "learning_rate": 0.0001,
    "weight_decay": 0.0005,
    "scheduler": "warmup_cosine",
    "batch_size": 128,
    "early_stopping": true,

    "target_supervised": {
      "enabled": true,
      "weight": 1.0
    },

    "dann": {
      "enabled": false
    },

    "coral": {
      "enabled": false
    },

    "consistency": {
      "enabled": false
    }
  },

  "augmentation": {
    "apply_probability": 0.25,

    "enabled_transforms": [
      "gaussian_noise",
      "amplitude_scale",
      "baseline_drift",
      "peak_broadening",
      "spectral_shift"
    ],

    "parameters": {
      "gaussian_noise_std": 0.03,
      "baseline_drift_strength": 0.07,
      "peak_broadening_sigma": 0.14,
      "spectral_shift": 1.8
    }
  },

  "metrics": {
