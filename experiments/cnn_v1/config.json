{
  "dataset": {
    "name": "spectral_classifier",
    "signal_length": 1000,
    "n_classes_full": 30,
    "n_classes_clinical": 5,
    "shared_classes": [
      0,
      2,
      3,
      5,
      6
    ],
    "already_normalised": true
  },
  "splits": {
    "reference": {
      "x_file": "X_reference.npy",
      "y_file": "y_reference.npy",
      "role": "source",
      "n_samples": 60000,
      "n_classes": 30,
      "samples_per_class": 2000,
      "use_for_preprocessor_fit": true
    },
    "finetune": {
      "x_file": "X_finetune.npy",
      "y_file": "y_finetune.npy",
      "role": "adaptation",
      "n_samples": 3000,
      "n_classes": 30,
      "samples_per_class": 100
    },
    "test": {
      "x_file": "X_test.npy",
      "y_file": "y_test.npy",
      "role": "holdout",
      "n_samples": 3000,
      "n_classes": 30,
      "samples_per_class": 100,
      "access_policy": "once"
    },
    "2018clinical": {
      "x_file": "X_2018clinical.npy",
      "y_file": "y_2018clinical.npy",
      "role": "ood_eval",
      "n_samples": 10000,
      "n_classes": 5,
      "samples_per_class": 2000,
      "eval_classes": [
        0,
        2,
        3,
        5,
        6
      ]
    },
    "2019clinical": {
      "x_file": "X_2019clinical.npy",
      "y_file": "y_2019clinical.npy",
      "role": "ood_eval",
      "n_samples": 2500,
      "n_classes": 5,
      "samples_per_class": 500,
      "eval_classes": [
        0,
        2,
        3,
        5,
        6
      ]
    }
  },
  "validation": {
    "strategy": "stratified_split",
    "source_split": "reference",
    "val_fraction": 0.2,
    "random_seed": 42
  },
  "preprocessing": {
    "per_sample_mean_subtraction": {
      "enabled": true
    },
    "savitzky_golay": {
      "enabled": true,
      "window_length": 11,
      "polyorder": 3
    },
    "global_standardisation": {
      "enabled": false,
      "fit_on": "reference"
    },
    "clip": {
      "enabled": true,
      "min_val": -3.0,
      "max_val": 3.0
    },
    "pipeline": [
      "per_sample_mean_subtraction",
      "savitzky_golay",
      "clip"
    ]
  },
  "augmentation": {
    "apply_probability": 0.5,
    "seed": 42,
    "steps": {
      "gaussian_noise": {
        "enabled": true,
        "max_std": 0.03
      },
      "baseline_shift": {
        "enabled": true,
        "max_shift": 0.08
      },
      "amplitude_scale": {
        "enabled": true,
        "factor": 0.1
      },
      "spectral_shift": {
        "enabled": true,
        "max_shift": 5
      }
    }
  },
  "training": {
    "max_epochs": 100,
    "batch_size": 256,
    "num_workers": 4,
    "optimizer": "adamw",
    "lr": 0.001,
    "weight_decay": 0.0001,
    "loss": "cross_entropy",
    "loss_kwargs": {},
    "scheduler": "cosine",
    "scheduler_cfg": {
      "T_max": 100,
      "eta_min": 1e-06
    },
    "early_stopping_patience": 10,
    "gradient_clip": 1.0,
    "finetune_lr": 0.0001,
    "finetune_epochs": 50,
    "finetune_patience": 8
  },
  "model": {
    "name": "cnn",
    "signal_length": 1000,
    "n_classes": 30,
    "channels": [
      32,
      64,
      128,
      256
    ],
    "kernel_sizes": [
      7,
      15,
      15,
      31
    ],
    "dropout": 0.3
  }
}